MCU = RP2040
BOOTLOADER = rp2040
PLATFORM = rp2040
PYTHON = python
CONSOLE_ENABLE = yes
# No ChibiOS or TMK dependencies for RP2040
STRICT = no
EXTRAFLAGS += -Wno-error
OLED_ENABLE = yes
I2C_DRIVER_REQUIRED = yes
OLED_DRIVER = ssd1306
OLED_COLUMN_OFFSET = 2
OLED_TIMEOUT = 0
OLED_DISPLAY_ADDRESS = 0x3C
